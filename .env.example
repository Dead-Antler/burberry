# =============================================================================
# Wrestling Prediction System - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# =============================================================================

# --- Required ---

# SQLite database file path (relative to project root)
DB_FILE_NAME=file:data/database.db

# Session signing secret (min 32 chars)
# Generate one with: openssl rand -base64 32
AUTH_SECRET=

# Public URL of the application
AUTH_URL=http://localhost:3000

# --- Admin User (first run) ---

# Email for the auto-created admin account on first startup
# If not set, no admin is created automatically
ADMIN_EMAIL=admin@example.com

# Optional: set a specific admin password
# If not set, a random password is generated and printed to the console
# ADMIN_PASSWORD=

# --- Optional ---

# Host port for Docker (default: 3000)
# The container always runs on 3000 internally; Docker maps this port to it
# PORT=3000

# Additional trusted origins for CSRF validation (comma-separated)
# AUTH_URL is always trusted. Add extra origins here for reverse proxy setups.
# Example: http://localhost:8080,https://staging.example.com
# TRUSTED_ORIGINS=

# Enable Drizzle ORM query logging (default: false)
# DB_LOGGING=true
